<?xml version="1.0" encoding="UTF-8"?>

<ExtensionManifest
    Version="7.0"
    ExtensionBundleId="com.vectorfactory.panel"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="Vector Factory"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension
            Id="com.vectorfactory.panel"
            Version="1.0.0"/>
    </ExtensionList>

    <ExecutionEnvironment>

        <HostList>
            <Host Name="ILST" Version="[17.0,99.9]" />
        </HostList>

        <LocaleList>
            <Locale Code="All"/>
        </LocaleList>

        <RequiredRuntimeList>
            <RequiredRuntime
                Name="CSXS"
                Version="11.0"/>
        </RequiredRuntimeList>

    </ExecutionEnvironment>

    <DispatchInfoList>

        <Extension Id="com.vectorfactory.panel">

            <DispatchInfo>

                <Resources>

                    <MainPath>./index.html</MainPath>

                    <ScriptPath>./jsx/VF_Common.jsx</ScriptPath>

                </Resources>

                <Lifecycle>

                    <AutoVisible>true</AutoVisible>

                </Lifecycle>

                <UI>

                    <Type>Panel</Type>

                    <Menu>Vector Factory</Menu>

                    <Geometry>

                        <Size>

                            <Width>200</Width>

                            <Height>300</Height>

                        </Size>

                        <MinSize>

                            <Width>200</Width>

                            <Height>300</Height>

                        </MinSize>

                    </Geometry>

                </UI>

            </DispatchInfo>

        </Extension>

    </DispatchInfoList>

</ExtensionManifest>